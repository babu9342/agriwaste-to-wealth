<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Farmer Register</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body style="background-color:#00FF9C;">
  <div class="container">
    <h2>Farmer Registration</h2>
    
  {{#if msg}}
  <p class="{{msg_type}}">{{msg}}</p>
  {{/if}}
    <form action="/auth/fregister" method="POST">
  <input type="text" name="name" placeholder="Name" required><br>
  <input type="text" name="village" placeholder="Village" required><br>
  <input type="email" name="email" placeholder="Email" required><br>
  <input type="password" name="password" placeholder="Password" required><br>
  <button type="submit">Register</button>
</form>
    <p>Already registered? <a href="/flogin">Login here</a></p>
    </form>
  </div>
</body>
</html>