<!DOCTYPE html>
<html>
<head>
    <title>Admin Dashboard</title>
    <style>
        body { 
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; 
            margin: 0; 
            padding: 0; 
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
        }
        .container { 
            max-width: 1400px; 
            margin: 20px auto; 
            background: white; 
            padding: 30px; 
            border-radius: 15px; 
            box-shadow: 0 10px 30px rgba(0,0,0,0.15); 
        }
        .header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 30px;
            padding-bottom: 20px;
            border-bottom: 2px solid #e0e0e0;
        }
        h1 {
            color: #2c3e50;
            margin: 0;
            font-size: 32px;
            font-weight: 700;
        }
        .logout-btn {
            background: linear-gradient(135deg, #ff6b6b, #ee5a52);
            color: white;
            padding: 12px 25px;
            text-decoration: none;
            border-radius: 25px;
            font-weight: 600;
            transition: all 0.3s ease;
            border: none;
            cursor: pointer;
        }
        .logout-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(255, 107, 107, 0.4);
        }
        .section {
            margin-bottom: 50px;
            background: white;
            border-radius: 12px;
            padding: 25px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.08);
        }
        h2 {
            color: #34495e;
            margin: 0 0 25px 0;
            padding-bottom: 15px;
            border-bottom: 2px solid #3498db;
            font-size: 24px;
        }
        table {
            width: 100%;
            border-collapse: collapse;
            margin: 20px 0;
            background: white;
            border-radius: 10px;
            overflow: hidden;
        }
        th {
            background: linear-gradient(135deg, #3498db, #2980b9);
            color: white;
            padding: 18px 15px;
            text-align: left;
            font-weight: 600;
            font-size: 15px;
        }
        td {
            padding: 16px 15px;
            border-bottom: 1px solid #ecf0f1;
            vertical-align: top;
        }
        tr:hover {
            background-color: #f8f9fa;
            transform: translateY(-1px);
            transition: all 0.2s ease;
        }
        .btn {
            padding: 10px 18px;
            border: none;
            border-radius: 6px;
            cursor: pointer;
            color: white;
            margin-right: 8px;
            font-weight: 600;
            transition: all 0.3s ease;
            text-decoration: none;
            display: inline-block;
        }
        .btn-accept {
            background: linear-gradient(135deg, #27ae60, #229954);
        }
        .btn-accept:hover {
            background: linear-gradient(135deg, #229954, #1e7e34);
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(39, 174, 96, 0.3);
        }
        .btn-reject {
            background: linear-gradient(135deg, #e74c3c, #c0392b);
        }
        .btn-reject:hover {
            background: linear-gradient(135deg, #c0392b, #a93226);
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(231, 76, 60, 0.3);
        }
        .logo-cell {
            text-align: center;
            width: 80px;
        }
        .company-logo {
            width: 60px;
            height: 60px;
            object-fit: cover;
            border-radius: 8px;
            border: 2px solid #3498db;
            transition: transform 0.3s ease;
        }
        .company-logo:hover {
            transform: scale(1.1);
        }
        .logo-placeholder {
            width: 60px;
            height: 60px;
            background: linear-gradient(45deg, #ecf0f1, #bdc3c7);
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #7f8c8d;
            font-size: 11px;
            font-weight: bold;
        }
        .no-data {
            text-align: center;
            padding: 40px;
            color: #7f8c8d;
            font-size: 18px;
            background: #f8f9fa;
            border-radius: 10px;
            margin: 20px 0;
        }
        .no-data i {
            font-size: 48px;
            margin-bottom: 15px;
            color: #bdc3c7;
        }
        .stats {
            display: flex;
            gap: 20px;
            margin-bottom: 30px;
        }
        .stat-card {
            flex: 1;
            background: white;
            padding: 25px;
            border-radius: 12px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.08);
            text-align: center;
        }
        .stat-number {
            font-size: 36px;
            font-weight: bold;
            color: #3498db;
            margin: 10px 0;
        }
        .stat-label {
            color: #7f8c8d;
            font-size: 14px;
            font-weight: 600;
        }
        .farmers-stat { border-top: 4px solid #27ae60; }
        .companies-stat { border-top: 4px solid #3498db; }
        
        @media (max-width: 1024px) {
            .container {
                margin: 10px;
                padding: 20px;
            }
            table {
                font-size: 14px;
            }
            th, td {
                padding: 12px 10px;
            }
            .stats {
                flex-direction: column;
            }
        }
        @media (max-width: 768px) {
            .header {
                flex-direction: column;
                gap: 15px;
                text-align: center;
            }
            table {
                display: block;
                overflow-x: auto;
            }
            .btn {
                display: block;
                margin: 5px 0;
                text-align: center;
            }
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="header">
            <h1>Admin Dashboard</h1>
            <a href="/admin/logout" class="logout-btn">Logout</a>
        </div>

        <div class="stats">
            <div class="stat-card farmers-stat">
                <div class="stat-label">Pending Farmer Submissions</div>
                <div class="stat-number">{{farmers.length}}</div>
            </div>
            <div class="stat-card companies-stat">
                <div class="stat-label">Pending Company Submissions</div>
                <div class="stat-number">{{companies.length}}</div>
            </div>
        </div>

        <!-- Farmer Submissions Section -->
        <div class="section">
            <h2>Pending Farmer Submissions</h2>
            {{#if farmers.length}}
            <table>
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Name</th>
                        <th>Email</th>
                        <th>Location</th>
                        <th>Waste Type</th>
                        <th>Quantity</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {{#each farmers}}
                    <tr>
                        <td>{{this.id}}</td>
                        <td><strong>{{this.name}}</strong></td>
                        <td>{{this.email}}</td>
                        <td>{{this.location}}</td>
                        <td>{{this.waste}}</td>
                        <td>{{this.quantity}}</td>
                        <td>
                            <a href="/admin/accept-farmer/{{this.id}}" class="btn btn-accept">Accept</a>
                            <a href="/admin/reject-farmer/{{this.id}}" class="btn btn-reject">Reject</a>
                        </td>
                    </tr>
                    {{/each}}
                </tbody>
            </table>
            {{else}}
            <div class="no-data">
                <div>📋</div>
                <p>No pending farmer submissions</p>
            </div>
            {{/if}}
        </div>

        <!-- Company Submissions Section -->
        <div class="section">
            <h2>Pending Company Submissions</h2>
            {{#if companies.length}}
            <table>
                <thead>
                    <tr>
                        <th>Logo</th>
                        <th>ID</th>
                        <th>Company Name</th>
                        <th>Email</th>
                        <th>Address</th>
                        <th>Quantity</th>
                        <th>Requirements</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {{#each companies}}
                    <tr>
                        <td class="logo-cell">
                            {{#if this.logo}}
                                <img src="/uploads/{{this.logo}}" class="company-logo" alt="Company Logo">
                            {{else}}
                                <div class="logo-placeholder">No Logo</div>
                            {{/if}}
                        </td>
                        <td>{{this.id}}</td>
                        <td><strong>{{this.company_name}}</strong></td>
                        <td>{{this.email}}</td>
                        <td>{{this.address}}</td>
                        <td>{{this.quantity}}</td>
                        <td>{{this.requirements}}</td>
                        <td>
                            <a href="/admin/accept-company/{{this.id}}" class="btn btn-accept">Accept</a>
                            <a href="/admin/reject-company/{{this.id}}" class="btn btn-reject">Reject</a>
                        </td>
                    </tr>
                    {{/each}}
                </tbody>
            </table>
            {{else}}
            <div class="no-data">
                <div>🏢</div>
                <p>No pending company submissions</p>
            </div>
            {{/if}}
        </div>
    </div>
</body>
</html>