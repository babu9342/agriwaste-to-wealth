<!DOCTYPE html>
<html>
<head>
    <title>Farmer Profile</title>
    <style>
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: linear-gradient(135deg, #d4f8d4, #b6f1b6);
            padding: 20px;
            margin: 0;
        }

        .container {
            max-width: 650px;
            margin: auto;
            background: white;
            padding: 30px;
            border-radius: 15px;
            box-shadow: 0 10px 25px rgba(0, 0, 0, 0.1);
            text-align: center;
            animation: fadeIn 0.6s ease-in-out;
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }

        h2 {
            color: #2f8f2f;
            margin-bottom: 20px;
            font-size: 28px;
            font-weight: bold;
        }

        .profile-photo {
            width: 160px;
            height: 160px;
            object-fit: cover;
            border-radius: 50%;
            border: 4px solid #38E54D;
            box-shadow: 0 6px 15px rgba(56, 229, 77, 0.3);
            transition: transform 0.3s ease, box-shadow 0.3s ease;
        }

        .profile-photo:hover {
            transform: scale(1.05);
            box-shadow: 0 8px 20px rgba(56, 229, 77, 0.5);
        }

        .label {
            font-weight: bold;
            margin-top: 15px;
            display: block;
            color: #333;
            font-size: 16px;
        }

        span {
            display: block;
            font-size: 15px;
            color: #555;
            margin-top: 4px;
        }

        img.waste-photo {
            width: 100%;
            max-width: 350px;
            margin-top: 10px;
            border-radius: 12px;
            box-shadow: 0 6px 15px rgba(0, 0, 0, 0.1);
            transition: transform 0.3s ease, box-shadow 0.3s ease;
        }

        img.waste-photo:hover {
            transform: scale(1.03);
            box-shadow: 0 8px 20px rgba(0,0,0,0.15);
        }

        .btn-container {
            margin-top: 20px;
            display: flex;
            justify-content: center;
            gap: 15px;
        }

        button {
            background: #38E54D;
            color: white;
            padding: 12px 25px;
            border: none;
            border-radius: 8px;
            cursor: pointer;
            font-size: 15px;
            transition: background 0.3s ease, transform 0.2s ease;
        }

        button:hover {
            background: #2ecc40;
            transform: translateY(-2px);
        }
    </style>
</head>
<body>
    <div class="container">
        <h2>Farmer Profile</h2>

        <!-- Farmer Photo -->
        {{#if submission.farmerPhoto}}
          <img src="{{submission.farmerPhoto}}" alt="Farmer Photo" class="profile-photo">
        {{else}}
          <img src="/images/default-profile.png" alt="Farmer Photo" class="profile-photo">
        {{/if}}

        <div>
            <span class="label">Name:</span>
            <span>{{submission.name}}</span>

            <span class="label">Email:</span>
            <span>{{submission.email}}</span>

            <span class="label">Location:</span>
            <span>{{submission.location}}</span>

            <span class="label">Waste Details:</span>
            <span>{{submission.waste}}</span>

            <span class="label">Waste Photo:</span>
            {{#if submission.wastePhoto}}
              <img src="{{submission.wastePhoto}}" alt="Waste Photo" class="waste-photo">
            {{else}}
              <p>No waste photo uploaded</p>
            {{/if}}
        </div>

        <div class="btn-container">
            <button onclick="window.location.href='/farmer/dashboard'">Back</button>
            <button onclick="window.location.href='/'">Go Home</button>
        </div>
    </div>
</body>
</html>
